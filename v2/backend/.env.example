# Yerelde development kalabilir; Render pilotta production onerilir.
CK_V2_APP_ENV=development
# Render pilot ornegi:
# CK_V2_APP_ENV=production
# CK_V2_RENDER_SERVICE_NAME=crmcatkapinda-v2-api
# CK_V2_RELEASE_SHA=<opsiyonel-manuel>
# CK_V2_DATABASE_URL tercih edilir, yoksa plain DATABASE_URL da okunur.
CK_V2_DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
CK_V2_FRONTEND_BASE_URL=http://127.0.0.1:3000
CK_V2_PUBLIC_APP_URL=http://127.0.0.1:3000
CK_V2_API_PUBLIC_URL=http://127.0.0.1:8000
CK_V2_DEFAULT_AUTH_PASSWORD=123456
AUTH_EBRU_PHONE=05xxxxxxxxx
AUTH_MERT_PHONE=05xxxxxxxxx
AUTH_MUHAMMED_PHONE=05xxxxxxxxx
SMS_PROVIDER=netgsm
SMS_API_URL=https://api.netgsm.com.tr/sms/rest/v2/send
SMS_NETGSM_USERNAME=8508409717
SMS_NETGSM_PASSWORD=your-netgsm-api-password
SMS_SENDER=CATKAPINDA
SMS_NETGSM_ENCODING=TR
