# Tum istemci cagrilari frontend icindeki /v2-api proxy rotasina gider.
NEXT_PUBLIC_V2_API_BASE_URL=/v2-api

# Yerelde opsiyonel; Render pilotta sabit servis adi gibi davranir.
CK_V2_FRONTEND_SERVICE_NAME=crmcatkapinda-v2
# Render RENDER_GIT_COMMIT'i otomatik verir; istersen yerelde manuel de tanimlayabilirsin.
# CK_V2_FRONTEND_RELEASE_SHA=<opsiyonel-manuel>

# Yerelde frontend ayaga kalkarken backend hedefini acik URL ile ver.
CK_V2_INTERNAL_API_BASE_URL=http://127.0.0.1:8000

# Render pilotunda bunu elle girme; blueprint backend servisinden otomatik doldurur.
# CK_V2_INTERNAL_API_HOSTPORT=crmcatkapinda-v2-api:10000
